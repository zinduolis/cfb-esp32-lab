#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

if [[ "$#" -lt 1 ]]; then
  echo "Usage: bin/arduino-ota-upload <device-ip-or-url> [sketch-path] [fqbn]" >&2
  exit 1
fi

TARGET_URL="${1}"
SKETCH_PATH="${2:-sketches/hello_oled}"
FQBN="${3:-esp32:esp32:esp32c3:CDCOnBoot=cdc}"

if [[ "${SKETCH_PATH}" = /* ]]; then
  if [[ "${SKETCH_PATH}" != "${REPO_ROOT}"/* ]]; then
    echo "Sketch path must be inside ${REPO_ROOT}" >&2
    exit 1
  fi
  RELATIVE_SKETCH_PATH="${SKETCH_PATH#${REPO_ROOT}/}"
else
  RELATIVE_SKETCH_PATH="${SKETCH_PATH}"
fi

SKETCH_NAME="$(basename "${RELATIVE_SKETCH_PATH}")"
OUTPUT_DIR="/tmp/arduino-build/${SKETCH_NAME}"

if [[ "${TARGET_URL}" != http://* && "${TARGET_URL}" != https://* ]]; then
  TARGET_URL="http://${TARGET_URL}"
fi

if [[ "${TARGET_URL}" != */ota ]]; then
  TARGET_URL="${TARGET_URL%/}/ota"
fi

exec "${SCRIPT_DIR}/docker-run" bash -c "arduino-cli compile --fqbn '${FQBN}' --output-dir '${OUTPUT_DIR}' '/workspace/${RELATIVE_SKETCH_PATH}' && curl --fail --show-error -H 'Content-Type: application/octet-stream' --data-binary @'${OUTPUT_DIR}/${SKETCH_NAME}.ino.bin' '${TARGET_URL}'"
