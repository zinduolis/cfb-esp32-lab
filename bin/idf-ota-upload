#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

if [[ "$#" -lt 1 ]]; then
  echo "Usage: bin/idf-ota-upload <device-ip-or-url> [project-path]" >&2
  exit 1
fi

TARGET_URL="${1}"
PROJECT_PATH="${2:-ota_base_fw}"

if [[ "${PROJECT_PATH}" = /* ]]; then
  if [[ "${PROJECT_PATH}" != "${REPO_ROOT}"/* ]]; then
    echo "Project path must be inside ${REPO_ROOT}" >&2
    exit 1
  fi
  RELATIVE_PROJECT_PATH="${PROJECT_PATH#${REPO_ROOT}/}"
else
  RELATIVE_PROJECT_PATH="${PROJECT_PATH}"
fi

if [[ "${TARGET_URL}" != http://* && "${TARGET_URL}" != https://* ]]; then
  TARGET_URL="http://${TARGET_URL}"
fi

if [[ "${TARGET_URL}" != */ota ]]; then
  TARGET_URL="${TARGET_URL%/}/ota"
fi

exec "${SCRIPT_DIR}/docker-run" bash -lc "cd \"/workspace/${RELATIVE_PROJECT_PATH}\" && idf.py -B /tmp/idf-build build && curl --fail --show-error -H \"Content-Type: application/octet-stream\" --data-binary @/tmp/idf-build/workshop_firmware.bin \"${TARGET_URL}\""
